---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 px-6 text-center">
    <span class="text-5xl">🌿</span>
    <h1 class="text-3xl font-semibold">Plantopia</h1>
    <p class="max-w-md text-slate-400">
      Migración a Astro + Supabase en progreso. Infraestructura base lista;
      el CRUD de plantas y la autenticación vienen en la siguiente etapa.
    </p>
  </main>
</Layout>
